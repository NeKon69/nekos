#!/usr/bin/env python3
import argparse
import json
import pathlib
import re
import sys


ROOT = pathlib.Path(__file__).resolve().parents[3]
FACTS = ROOT / ".opencode" / "reviewer" / "knowledge" / "facts.jsonl"


def flatten(value):
    if value is None:
        return ""
    if isinstance(value, str):
        return value
    if isinstance(value, list):
        return " ".join(flatten(item) for item in value)
    if isinstance(value, dict):
        return " ".join(flatten(item) for item in value.values())
    return str(value)


def field_score(fact, term):
    term_l = term.lower()
    score = 0
    weighted_fields = [
        ("files", 8),
        ("symbols", 8),
        ("subsystems", 6),
        ("aliases", 5),
        ("kind", 3),
        ("fact", 2),
        ("review_uses", 2),
        ("evidence", 1),
    ]
    for field, weight in weighted_fields:
        text = flatten(fact.get(field)).lower()
        if term_l in text:
            score += weight
        elif re.search(r"\b" + re.escape(term_l) + r"\b", text):
            score += weight
    return score


def print_fact(fact, score, show_json):
    if show_json:
        print(json.dumps(fact, sort_keys=True))
        return

    fact_id = fact.get("id", "<no-id>")
    print(f"## {fact_id}  [score {score}]")
    print(f"kind: {fact.get('kind', '<unknown>')}")
    for field in ("subsystems", "files", "symbols", "aliases"):
        values = fact.get(field) or []
        if values:
            print(f"{field}: {', '.join(str(v) for v in values)}")
    print()
    print(fact.get("fact", "").strip())
    review_uses = fact.get("review_uses") or []
    if review_uses:
        print("\nreview uses:")
        for item in review_uses:
            print(f"- {item}")
    evidence = fact.get("evidence") or []
    if evidence:
        print("\nevidence:")
        for item in evidence:
            print(f"- {item}")
    print()


def main():
    parser = argparse.ArgumentParser(
        description="Search durable reviewer facts without reading the whole database."
    )
    parser.add_argument("terms", nargs="+", help="Search terms: paths, symbols, subsystems, aliases")
    parser.add_argument("--limit", type=int, default=10, help="Maximum facts to print")
    parser.add_argument("--json", action="store_true", help="Print raw matching JSONL records")
    args = parser.parse_args()

    if not FACTS.exists():
        print(f"No facts database found: {FACTS}", file=sys.stderr)
        return 1

    matches = []
    with FACTS.open(encoding="utf-8") as handle:
        for line_no, line in enumerate(handle, 1):
            line = line.strip()
            if not line:
                continue
            try:
                fact = json.loads(line)
            except json.JSONDecodeError as err:
                print(f"Skipping invalid JSONL line {line_no}: {err}", file=sys.stderr)
                continue
            score = sum(field_score(fact, term) for term in args.terms)
            if score:
                matches.append((score, line_no, fact))

    matches.sort(key=lambda item: (-item[0], item[1]))
    for score, _line_no, fact in matches[: args.limit]:
        print_fact(fact, score, args.json)

    if not matches:
        print("No matching reviewer facts found.", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
